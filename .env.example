# Shopify Storefront API
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-token

# Judge.me Product Reviews
NEXT_PUBLIC_JUDGEME_PUBLIC_TOKEN=your-public-token
JUDGEME_PRIVATE_TOKEN=your-private-token
NEXT_PUBLIC_JUDGEME_SHOP_DOMAIN=your-shop.myshopify.com

# Klaviyo Email Marketing
NEXT_PUBLIC_KLAVIYO_PUBLIC_KEY=your-public-key
KLAVIYO_LIST_ID=your-list-id

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Razorpay Payment Gateway
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your-key-secret

# Brand Video (optional — falls back to placeholder)
NEXT_PUBLIC_BRAND_VIDEO_URL=https://your-video-url.mp4
